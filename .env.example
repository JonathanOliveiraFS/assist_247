# ---------------------------------------------------------
# IA & RAG (Caminhos internos do Docker)
# ---------------------------------------------------------
OPENAI_API_KEY='sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX'
GITHUB_TOKEN='ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX'

# O Docker mapeou a pasta C:\...\rag_data para /app/rag_data
CHROMA_PERSIST_DIR='/app/rag_data/chromadb'
BM25_INDEX_DIR='/app/rag_data/bm25_indexes'

# ---------------------------------------------------------
# WHATSAPP (Acessando o container evolution-api)
# ---------------------------------------------------------
EVOLUTION_API_URL='http://evolution-api:8080'
EVOLUTION_API_KEY='SUA_EVOLUTION_API_KEY_AQUI'

# Configurações de Transbordo (HITL)
ADMIN_NUMBER=5500000000000@s.whatsapp.net
ADMIN_INSTANCE=integra_ai
TRANSBORDO_TIMEOUT_24H=86400

# Configurações do Airtable para a BIA
AIRTABLE_API_KEY=patXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Agendamentos

# Notion CRM Configs
NOTION_API_KEY=ntn_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_DATABASE_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Configurações do Redis para a Evolution API
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/0
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLE=false

# ---------------------------------------------------------
# INFRAESTRUTURA BASE
# ---------------------------------------------------------
# Senha usada pelo Postgres no docker-compose
DB_PASSWORD='senha_forte_aqui'
POSTGRES_PASSWORD='senha_forte_aqui'

# Acessando o container redis na porta padrão
REDIS_URL='redis://redis:6379/0'

# Acessando o Kestra
KESTRA_API_URL='http://host.docker.internal:8081'
KESTRA_WEBHOOK_KEY=sua_chave_webhook_aqui

# ---------------------------------------------------------
# BANCO DE DADOS DA EVOLUTION API
# ---------------------------------------------------------
DATABASE_PROVIDER=postgresql
# O formato é: postgresql://usuario:senha@host:porta/banco
DATABASE_CONNECTION_URI='postgresql://postgres:senha_forte_aqui@postgres:5432/postgres'

# ---------------------------------------------------------
# MCP SERVERS CONFIG (Acessando os containers internos)
# ---------------------------------------------------------
MCP_SERVERS_CONFIG='{"agenda": "http://mcp-agenda:8001", "crm": "http://mcp-crm:8002"}'
